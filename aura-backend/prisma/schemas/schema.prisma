datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// 📑 ฐานข้อมูลกลาง: เก็บ Log ระบบ
// ==========================================
model AuditLogs {
  id           Int      @id @default(autoincrement())
  action_user  String   @db.VarChar(100)
  search_key   String   @db.VarChar(100)
  browser_info String?  @db.VarChar(255)
  ip_address   String?  @db.VarChar(50)
  created_at   DateTime @default(now()) @db.DateTime
}

// ==========================================
// 📑 ฐานข้อมูลกลาง: เก็บสิทธิ์ไอทีแอดมินสำหรับระบบ AURA
// ==========================================
model User {
  id        Int      @id @default(autoincrement())
  user      String   @unique @db.VarChar(50)  // เอาไว้พิมพ์ช่อง Username
  pwd       String   @db.VarChar(255)         // เอาไว้พิมพ์ช่อง Password
  name      String?  @db.VarChar(100)
  level     String?  @db.VarChar(20)          // ระดับสิทธิ์ เช่น admin, staff
  createdAt DateTime @default(now()) @db.DateTime

  @@map("AuraUser") // แอบผูกชื่อตารางในฐานข้อมูลว่า AuraUser จะได้เป็นสัดส่วนชัดเจนครับ
}

