datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}


model AuditLogs {
  id           Int      @id @default(autoincrement())
  action_user  String   @db.VarChar(100)  // ชื่อผู้ดูแลระบบที่ทำรายการ
  search_key   String   @db.VarChar(100)  // คำค้นหาที่ใช้ค้นหาพนักงาน
  browser_info String?  @db.VarChar(255) // ข้อมูลเว็บเบราว์เซอร์ที่ใช้เข้าใช้งาน
  ip_address   String?  @db.VarChar(50) // ที่อยู่ IP ของผู้ใช้
  created_at   DateTime @default(now()) @db.DateTime
}

model User {
  id        Int      @id @default(autoincrement())
  user      String   @unique @db.VarChar(50)  
  pwd       String   @db.VarChar(255)         
  name      String?  @db.VarChar(100)
  level     String?  @db.VarChar(20)         
  createdAt DateTime @default(now()) @db.DateTime

  @@map("AuraUser") 
}

